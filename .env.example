# Earnandheal Environment Variables

# Firebase config (AI Studio will inject this into firebase-applet-config.json)
# GEMINI_API_KEY is injected into vite.config.ts

# App URL for SEO and callbacks
VITE_APP_URL="https://your-app-url.com"

# Analytics and Adsense (Placeholders for user to fill)
VITE_GOOGLE_ANALYTICS_ID=""
VITE_GOOGLE_ADSENSE_CLIENT_ID=""
