{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Tool": {
      "title": "Tool",
      "description": "A utility tool metadata.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "slug": { "type": "string" },
        "icon": { "type": "string" },
        "popular": { "type": "boolean" },
        "featured": { "type": "boolean" },
        "usageCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "slug", "category"]
    },
    "BlogPost": {
      "title": "Blog Post",
      "description": "An SEO-optimized article.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "categoryId": { "type": "string" },
        "tags": { "type": "array" },
        "featuredImage": { "type": "string" },
        "publishedAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "seoTitle": { "type": "string" },
        "seoDescription": { "type": "string" }
      },
      "required": ["id", "title", "slug", "content", "authorId", "publishedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile collection."
    },
    "/tools/{toolId}": {
      "schema": "Tool",
      "description": "Utility tools collection."
    },
    "/blogPosts/{postId}": {
      "schema": "BlogPost",
      "description": "Blog articles collection."
    }
  }
}
